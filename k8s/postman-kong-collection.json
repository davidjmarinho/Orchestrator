{
  "info": {
    "_postman_id": "f3a92b10-1234-4abc-8def-fiapfase3kong",
    "name": "Kong API Gateway — FIAP Fase 3",
    "description": "Testa as políticas do Kong configuradas via kong-setup.sh.\n\nPré-requisito:\n  kubectl port-forward svc/kong-proxy 9080:80 -n fcg-tech-fase-2\n\nO JWT é gerado automaticamente no Pre-request Script da coleção.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:9080", "type": "string" },
    { "key": "jwt_token", "value": "GERADO_AUTOMATICAMENTE", "type": "string" },
    { "key": "email_test", "value": "teste@email.com", "type": "string" },
    { "key": "password_test", "value": "senha123", "type": "string" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Gera JWT HS256 com iss=UsersAPI (compatível com kong-setup.sh)",
          "function base64url(str) {",
          "    return btoa(unescape(encodeURIComponent(str)))",
          "        .replace(/=/g,'').replace(/\\+/g,'-').replace(/\\//g,'_');",
          "}",
          "const now = Math.floor(Date.now() / 1000);",
          "const header  = base64url(JSON.stringify({ alg: 'HS256', typ: 'JWT' }));",
          "const payload = base64url(JSON.stringify({",
          "    iss: 'UsersAPI',",
          "    sub: 'test-user',",
          "    iat: now,",
          "    exp: now + 86400",
          "}));",
          "const sigInput = header + '.' + payload;",
          "const secret   = 'ChaveSuperSecretaCom32Caracteres!';",
          "const sig = CryptoJS.HmacSHA256(sigInput, secret)",
          "    .toString(CryptoJS.enc.Base64)",
          "    .replace(/=/g,'').replace(/\\+/g,'-').replace(/\\//g,'_');",
          "const jwt = sigInput + '.' + sig;",
          "pm.collectionVariables.set('jwt_token', jwt);"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "🔓 Rotas Públicas (sem JWT)",
      "item": [
        {
          "name": "POST Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Usuário Teste\",\n  \"email\": \"{{email_test}}\",\n  \"password\": \"{{password_test}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/users/register", "host": ["{{base_url}}"], "path": ["api","users","register"] },
            "description": "Rota pública — Kong não exige JWT.\nEsperado: 200/201 (backend OK) ou 502 (backend offline, mas Kong aceitou)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Kong não retornou 401 (rota pública)', function() {",
                  "    pm.expect(pm.response.code).to.not.equal(401);",
                  "});",
                  "pm.test('Kong respondeu (não timeout)', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200,201,400,404,500,502,503]);",
                  "});"
                ]
              }
            }
          ]
        },
