  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// =====================================================",
          "// JWT Auto-Generator (HS256) — compatível com kong-setup.sh",
          "// Gera um token válido por 24h com iss=UsersAPI",
          "// Este token é aceito pelo Kong porque o consumer",
          "// app-consumer tem credencial JWT com key=UsersAPI",
          "// e secret=ChaveSuperSecretaCom32Caracteres!",
          "// =====================================================",
          "",
          "function base64url(str) {",
          "    return btoa(unescape(encodeURIComponent(str)))",
          "        .replace(/=/g, '').replace(/\\+/g, '-').replace(/\\//g, '_');",
          "}",
          "",
          "const now = Math.floor(Date.now() / 1000);",
          "const header = base64url(JSON.stringify({ alg: 'HS256', typ: 'JWT' }));",
          "const payload = base64url(JSON.stringify({",
          "    iss: 'UsersAPI',",
          "    sub: 'postman-test-user',",
          "    iat: now,",
          "    exp: now + 86400",
          "}));",
          "",
          "const sigInput = header + '.' + payload;",
          "const secret = 'ChaveSuperSecretaCom32Caracteres!';",
          "const sig = CryptoJS.HmacSHA256(sigInput, secret)",
          "    .toString(CryptoJS.enc.Base64)",
          "    .replace(/=/g, '').replace(/\\+/g, '-').replace(/\\//g, '_');",
          "",
          "const jwt = sigInput + '.' + sig;",
          "pm.collectionVariables.set('jwt_token', jwt);",
          "",
          "// Gerar email único se não existir",
          "if (!pm.collectionVariables.get('test_email') || pm.collectionVariables.get('test_email') === '') {",
          "    const ts = Date.now();",
          "    pm.collectionVariables.set('test_email', 'postman' + ts + '@fcgtech.com');",
          "}"
        ]
      }
    }
  ],
  "item": [
