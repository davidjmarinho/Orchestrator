              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/users/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "register"
              ]
            },
            "description": "## Rota Pública — Kong NÃO exige JWT\n\nO Kong roteia `/api/users/register` direto para o backend sem validar autenticação.\n\nEsperado: **201 Created** + body com `id`, `email`, `fullName`\n\nO `id` do usuário é salvo automaticamente na variável `user_id`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Rota pública: Kong não deve retornar 401",
                  "pm.test('Kong roteou sem exigir JWT (rota pública)', function () {",
                  "    pm.expect(pm.response.code).to.not.equal(401);",
                  "});",
